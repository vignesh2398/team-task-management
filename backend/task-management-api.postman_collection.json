{
  "info": {
    "name": "Task Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for task management backend endpoints."
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["health"]
        }
      }
    },
    {
      "name": "Get All Tasks",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/tasks",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["tasks"]
        }
      }
    },
    {
      "name": "Get Task By ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/tasks/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["tasks", "1"]
        }
      }
    },
    {
      "name": "Create Task",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"New Task\",\n  \"description\": \"Describe the new task.\",\n  \"priority\": \"medium\",\n  \"status\": \"todo\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/tasks",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["tasks"]
        }
      }
    },
    {
      "name": "Update Task",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Updated Task Title\",\n  \"description\": \"Updated description.\",\n  \"priority\": \"high\",\n  \"status\": \"in-progress\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/tasks/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["tasks", "1"]
        }
      }
    },
    {
      "name": "Delete Task",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "x-delete-task-auth",
            "value": "task-delete-secret"
          }
        ],
        "url": {
          "raw": "http://localhost:3000/tasks/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["tasks", "1"]
        }
      }
    }
  ]
}
